<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	xmlns:tools="http://schemas.android.com/tools"
			  android:layout_width="match_parent"
			  android:layout_height="match_parent">

	<androidx.appcompat.widget.AppCompatCheckBox
		android:id="@+id/applyToAllCheckBox"
		style="?attr/dialogCheckBoxStyle"
		android:layout_width="0dp"
		android:layout_height="wrap_content"
		android:layout_gravity="center"
		android:text="@string/overwrite_files_apply_to_all"
		android:layout_marginStart="@dimen/dialog_overwrite_checkbox_margin"
		android:layout_marginEnd="@dimen/dialog_overwrite_checkbox_margin"
		android:layout_marginTop="@dimen/dialog_overwrite_checkbox_margin"
		android:lines="1"
		android:ellipsize="end"
		android:textColor="@color/dialog_content_text"
		app:layout_constraintBottom_toBottomOf="parent"
		app:layout_constraintEnd_toEndOf="parent"
		app:layout_constraintStart_toStartOf="parent"
		app:layout_constraintTop_toTopOf="parent"
		tools:text="Apply to all" />

</androidx.constraintlayout.widget.ConstraintLayout>