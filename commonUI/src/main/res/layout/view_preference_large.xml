<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
	style="@style/PreferenceRootViewStyle"
	xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:tools="http://schemas.android.com/tools">

	<include layout="@layout/view_preference_image_view"/>

	<LinearLayout
		android:layout_width="wrap_content"
		android:layout_height="wrap_content"
		android:layout_marginLeft="@dimen/view_preference_large_more_image_content_margin_left"
		android:layout_weight="1"
		android:gravity="center_vertical"
		android:orientation="vertical">

		<com.strato.hidrive.common_ui.stylized.StylizedTextView
			android:id="@android:id/title"
			style="@style/PreferenceTitleStyle"
			tools:text="Title"/>

		<com.strato.hidrive.common_ui.stylized.StylizedTextView
			android:id="@android:id/summary"
			style="@style/PreferenceSubtitleStyle.Large"
			tools:text="Summary"/>

	</LinearLayout>

	<!-- Preference should place its actual preference widget here. -->
	<include layout="@layout/view_preference_widget_frame"/>
</LinearLayout>
