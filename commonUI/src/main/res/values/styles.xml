<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="MaterialSwitchStyle">
        <item name="colorPrimary">@color/accent_color</item>
        <item name="colorPrimaryDark">@color/accent_color</item>
        <item name="colorAccent">@color/accent_color</item>
    </style>

    <style name="PreferenceCategoryTitleStyle">
        <item name="android:textSize">@dimen/preference_category_text_size</item>
        <item name="android:textColor">@color/preference_item_title_text</item>
        <item name="android:gravity">top</item>
        <item name="android:paddingTop">@dimen/preference_category_top_margin</item>
    </style>

    <style name="PreferenceTitleStyle">
        <item name="android:textSize">@dimen/preference_item_title_text_size</item>
        <item name="android:textColor">@color/preference_item_title_text</item>
        <item name="android:singleLine">true</item>
        <item name="android:ellipsize">end</item>
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
    </style>

    <style name="ButtonStyle" parent="android:Widget.Button">
        <item name="android:background">@null</item>
    </style>

    <style name="PreferenceStyle" parent="PreferenceThemeOverlay">
        <item name="android:dividerHeight">1dp</item>
    </style>

    <style name="Theme.App" parent="Theme.AppCompat.DayNight">
        <item name="android:buttonStyle">@style/ButtonStyle</item>
        <item name="preferenceTheme">@style/PreferenceStyle</item>
    </style>

    <style name="DialogCheckBoxTheme" parent="Theme.App">
        <item name="colorControlNormal">@color/dialog_check_box_normal_color</item>
        <item name="colorControlActivated">@color/dialog_check_box_activated_color</item>
    </style>

    <style name="DialogCheckBoxStyle" parent="Theme.App">
        <item name="android:theme">@style/DialogCheckBoxTheme</item>
    </style>

    <style name="ItemViewCheckBoxStyle" parent="Theme.App">
        <item name="android:theme">@style/ItemViewCheckBoxTheme</item>
    </style>

    <style name="ItemViewCheckBoxTheme" parent="Theme.App">
        <item name="colorControlNormal">@color/item_view_check_box_normal_color</item>
        <item name="colorControlActivated">@color/item_view_check_box_activated_color</item>
    </style>

    <style name="Theme.App.NoTitleBar" parent="Theme.AppCompat.DayNight">
        <item name="windowNoTitle">true</item>
        <item name="windowActionBar">false</item>
        <item name="android:windowBackground">@color/main_screen_container_background</item>
        <item name="dialogCheckBoxStyle">@style/DialogCheckBoxStyle</item>
        <item name="itemViewCheckBoxStyle">@style/ItemViewCheckBoxStyle</item>
        <item name="colorAccent">@color/accent_color</item>
    </style>

    <style name="PreferenceGeneralStyle" parent="Theme.App.NoTitleBar">
        <item name="android:textColorPrimary">@color/dialog_title_color</item> //title, edit text
        <item name="colorAccent">@color/dialog_buttons_color</item> // ok, cancel
        <item name="android:textColorSecondary">@color/deactivated_control_color</item> //unselected radio
        <item name="colorControlActivated">@color/activated_control_color</item> //selected radio, text underline, switcher ON
    </style>

    <style name="PreferenceSubtitleStyle">
        <item name="android:textSize">@dimen/preference_item_subtitle_text_size</item>
        <item name="android:textColor">@color/preference_item_subtitle_text</item>
    </style>

    <style name="PreferenceSubtitleStyle.Large">
        <item name="android:gravity">center_vertical</item>
        <item name="android:maxLines">2</item>
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">@dimen/preference_subtitle_text_size</item>
    </style>

    <style name="PreferenceSubtitleStyle.Small">
        <item name="android:textSize">@dimen/preference_item_subtitle_text_size_small</item>
        <item name="android:singleLine">true</item>
        <item name="android:ellipsize">end</item>
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
    </style>

    <style name="PreferenceRootViewStyle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:minHeight">?android:attr/listPreferredItemHeight</item>
        <item name="android:paddingLeft">@dimen/preference_item_left_right_padding</item>
        <item name="android:paddingRight">@dimen/preference_item_left_right_padding</item>
        <item name="android:background">@color/view_preference_item_background</item>
    </style>

    <style name="PreferenceButtonStyle">
        <item name="android:textSize">@dimen/preference_button_text_size</item>
        <item name="android:textColor">@color/preference_button_text</item>
        <item name="android:background">@drawable/selector_preference_button</item>
        <item name="android:minHeight">@dimen/preference_button_min_height</item>
        <item name="android:minWidth">@dimen/preference_button_min_width</item>
    </style>

    <style name="StylizedEditTextStyle">
        <item name="android:singleLine">true</item>
        <item name="android:textSize">@dimen/stylized_edit_text_text_size</item>
        <item name="android:textColor">@color/stylized_edit_text_text_color</item>
        <item name="android:textColorHighlight">@color/stylized_edit_text_highlight_color</item>
        <item name="android:textCursorDrawable">@null</item>
        <item name="android:theme">@style/StylizedEditTextTheme</item>
        <item name="selectedTextColor">@color/stylized_edit_text_selected_text_color</item>
    </style>

    <style name="StylizedEditTextTheme">
        <item name="colorControlActivated">@color/stylized_edit_text_select_handler_color</item>
    </style>

</resources>
