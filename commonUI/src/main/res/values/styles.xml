<?xml version="1.0" encoding="utf-8"?>
<resources>

 <style name="StylizedEditTextStyle">
        <item name="android:singleLine">true</item>
        <item name="android:textSize">@dimen/stylized_edit_text_text_size</item>
        <item name="android:textColor">@color/stylized_edit_text_text_color</item>
        <item name="android:textColorHighlight">@color/stylized_edit_text_highlight_color</item>
        <item name="android:textCursorDrawable">@null</item>
        <item name="android:theme">@style/StylizedEditTextTheme</item>
        <item name="selectedTextColor">@color/stylized_edit_text_selected_text_color</item>
    </style>

    <style name="StylizedEditTextTheme">
        <item name="colorControlActivated">@color/stylized_edit_text_select_handler_color</item>
    </style>

</resources>
