<resources>
    <style name="ScanbotFilterControlSeekBar" parent="Widget.AppCompat.SeekBar">
        <item name="android:progressBackgroundTint">@drawable/scanbot_filter_controls_seek_bar_progress_background</item>
        <item name="android:progressTint">@drawable/scanbot_filter_controls_seek_bar_progress</item>
        <item name="android:thumbTint">@drawable/scanbot_filter_controls_seek_bar_thumb</item>
    </style>

    <style name="ScanbotRadioGroupStyle" parent="Theme.AppCompat.DayNight">
        <item name="colorAccent">@color/scanbot_file_type_text_color_checked</item>
    </style>

    <style name="BottomNavigationItem">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
    </style>

    <style name="FabButtonBackgroundShape" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">8dp</item>
    </style>

    <style name="ScanbotDialogStyle" parent="Theme.AppCompat.Dialog">
        <item name="android:windowBackground">@color/scanbot_dialog_background_color</item>
        <item name="colorAccent">@color/scanbot_dialog_progress_color</item>
        <item name="android:textColor">@color/scanbot_dialog_text_color</item>
        <item name="android:textColorSecondary">@color/scanbot_dialog_progress_background_color</item>
        <item name="android:buttonBarNegativeButtonStyle">@style/ScanbotDialogNegativeButtonStyle</item>
    </style>

    <style name="ScanbotDialogNegativeButtonStyle" parent="Widget.AppCompat.Button.ButtonBar.AlertDialog">
        <item name="android:textColor">@color/scanbot_dialog_negative_button_text_color</item>
    </style>

</resources>
