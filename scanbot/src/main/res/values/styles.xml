<resources>
    <style name="ScanbotFilterControlSeekBar" parent="Widget.AppCompat.SeekBar">
        <item name="android:progressBackgroundTint">@drawable/scanbot_filter_controls_seek_bar</item>
        <item name="android:progressTint">@drawable/scanbot_filter_controls_seek_bar</item>
        <item name="android:thumbTint">@drawable/scanbot_filter_controls_seek_bar</item>
    </style>

    <style name="ScanbotRadioGroupStyle" parent="Theme.AppCompat.DayNight">
        <item name="colorAccent">@color/scanbot_file_type_text_color_checked</item>
    </style>

    <style name="BottomNavigationImageView">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">@dimen/scanbot_gallery_navigation_item_height</item>
        <item name="android:layout_margin">@dimen/common_material_dimen</item>
        <item name="android:layout_weight">1</item>
        <item name="android:tint">@color/scanbot_gallery_bottom_navigation_icon_color</item>
    </style>

</resources>
