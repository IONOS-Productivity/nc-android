<?xml version="1.0" encoding="utf-8"?>
<androidx.appcompat.widget.Toolbar xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:tools="http://schemas.android.com/tools"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	android:id="@+id/searchToolbar"
	android:layout_width="match_parent"
	android:layout_height="@dimen/navigation_layout_height"
	android:background="@color/app_bar_read_mode_color">

	<LinearLayout
		android:layout_width="match_parent"
		android:layout_height="match_parent"
		android:gravity="center_vertical">

		<ImageView
			android:id="@+id/ivBack"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:src="@drawable/ic_arrow_back_white_24dp"/>

		<TextView
			android:id="@+id/tvTitle"
			android:layout_width="0dp"
			android:layout_height="match_parent"
			android:layout_marginLeft="25dp"
            android:layout_weight="1"
			android:background="@color/transparent"
			android:gravity="center"
			android:lines="1"
			android:padding="@dimen/common_normal_padding"
			android:paddingRight="@dimen/ti_item_padding_right"
			android:textColor="@color/scanbot_toolbar_text_color"
			android:textSize="@dimen/scanbot_text_size"
			android:textStyle="bold"
			tools:text="Document Name"/>

		<TextView
			android:id="@+id/tvSave"
			android:layout_width="wrap_content"
			android:layout_height="match_parent"
			android:background="@color/transparent"
			android:gravity="center_vertical"
			android:lines="1"
			android:padding="@dimen/common_normal_padding"
			android:paddingRight="@dimen/ti_item_padding_right"
			android:text="@string/save"
			android:textColor="@color/scanbot_toolbar_text_color"
			android:textSize="@dimen/scanbot_text_size"
			android:textStyle="bold"/>

		<ImageView
			android:id="@+id/ivMore"
			android:layout_width="wrap_content"
			android:layout_height="match_parent"
			android:paddingTop="@dimen/common_normal_padding"
			android:paddingEnd="@dimen/common_normal_padding"
			android:paddingBottom="@dimen/common_normal_padding"
			android:visibility="gone"
			app:srcCompat="@drawable/ic_more_vert_white_24dp"
			app:tint="@color/scanbot_toolbar_text_color" />

	</LinearLayout>

</androidx.appcompat.widget.Toolbar>
