<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rlContent"
    android:background="?scanbot_filter_control_background"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <include
        android:id="@+id/toolbar"
        layout="@layout/scanbot_view_common_toolbar"
        android:layout_width="match_parent"
        android:layout_height="@dimen/scanbot_navigation_layout_height"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintLeft_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/imageView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@id/filterControls"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar" />

    <com.ionos.scanbot.screens.filter.view.FilterControls
        android:id="@+id/filterControls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toTopOf="@id/tvApplyToAll"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/tvApplyToAll"
        android:layout_width="wrap_content"
        android:layout_height="48dp"
        android:paddingStart="@dimen/scanbot_padding_large"
        android:paddingEnd="@dimen/scanbot_padding_large"
        android:textColor="?scanbot_filter_apply_to_all_text_color"
        android:background="@drawable/scanbot_filter_apply_btn_bg"
        android:gravity="center"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginBottom="@dimen/scanbot_padding_normal"
        android:text="@string/scanbot_filter_popup_apply_for_all"/>

</androidx.constraintlayout.widget.ConstraintLayout>
